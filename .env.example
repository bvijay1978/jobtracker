# Copy this file to `.env` and adjust as needed. `.env` is git-ignored, so your
# local paths never get committed. Every setting is optional.

# Where the tracker database lives. Defaults to ./jobs.db in the project.
# JOBTRACKER_DB=./jobs.db

# A spreadsheet to import with `python migrate.py`.
# JOBTRACKER_XLSX=/path/to/your/tracker.xlsx

# An external SQLite database that another tool drops new roles into, for
# `python import_jobs.py` (or the in-app "Import new roles" button) to pull from.
# JOBTRACKER_IMPORT_DB=/path/to/incoming/jobs.db

# Where generated CV / cover-letter drafts are saved (default ./cvs, ./cover_letters).
# JOBTRACKER_CV_DIR=/path/to/your/CVs
# JOBTRACKER_COVER_LETTER_DIR=/path/to/your/CVs

# Profile the in-app CV builder reads. Copy profile.example.json to profile.json
# (git-ignored) and fill it in, or point this at another file.
# JOBTRACKER_PROFILE=/path/to/profile.json
